# alias for neofetch
alias nf=neofetch

# alias for nvim
alias vi=nvim

# alias for tmux
alias tx=tmux
alias ts=tmux-sessionizer

# alias for lsd
alias ls=lsd
alias la="lsd -a"

# alias for cmatrix
cm() {
  command cmatrix -C blue
  return
}

